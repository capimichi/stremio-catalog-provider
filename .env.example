# ==============================================================================
# Configurazione Database (MariaDB)
# ==============================================================================
# Credenziali per il container MariaDB 'db' (utilizzate da docker-compose)
DB_NAME=stremio_catalog
DB_USER=catalog_user
DB_PASSWORD=catalog_password
DB_ROOT_PASSWORD=root_secure_password
DB_HOST_PORT=3306

# URL di connessione per SQLAlchemy (utilizzato da web-api e worker)
# NOTA: Quando usi docker-compose, l'host del database deve essere il nome del servizio docker 'db'.
# Se invece esegui l'app localmente senza Docker, cambia 'db' in 'localhost'.
DATABASE_URL=mysql+pymysql://catalog_user:catalog_password@db/stremio_catalog

# ==============================================================================
# Configurazione API Chiavi & Integrazioni
# ==============================================================================
# Inserisci qui la tua chiave API di TMDB per scaricare i metadati in italiano
TMDB_API_KEY=your_tmdb_api_key_here

# URL di TorrServer
# NOTA: Se TorrServer gira in un container o host esterno, inserisci l'IP corretto.
# Se TorrServer è nella stessa macchina del docker-compose, puoi usare http://host.docker.internal:8090
TORRSERVER_BASE_URL=http://localhost:8090

# Autenticazione Basic Auth di TorrServer (lascia vuoto se TorrServer non è protetto da password)
TORRSERVER_USERNAME=
TORRSERVER_PASSWORD=

# ==============================================================================
# Sicurezza Dashboard Web Admin
# ==============================================================================
# Credenziali per accedere alla Web UI (http://localhost:8000/dashboard)
BASIC_AUTH_USERNAME=admin
BASIC_AUTH_PASSWORD=secure_password_here

# Porta su cui esporre l'API sul tuo PC
API_HOST_PORT=8000
